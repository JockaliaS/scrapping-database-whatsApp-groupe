# === PROVIDED BY COOLIFY (do not hardcode) ===
DATABASE_URL=postgresql://user:password@coolify-postgres:5432/radar
REDIS_URL=redis://coolify-redis:6379

# === JWT ===
JWT_SECRET=generate_with_openssl_rand_hex_64
JWT_EXPIRE_MINUTES=10080

# === AI (stored in DB after init, env is fallback) ===
GEMINI_API_KEY=

# === Evolution API (stored in DB after init, env is fallback) ===
EVOLUTION_API_URL=https://whatsapp-prod.jockaliaservices.fr/
EVOLUTION_API_KEY=

# === Hub & Spoke Security ===
# Generate with: openssl rand -hex 32
# Must be identical in Radar AND in the existing Node.js app
RADAR_WEBHOOK_SECRET=

# === App ===
APP_ENV=production
COMMIT_HASH=local
RUST_LOG=info
FRONTEND_URL=https://radar.jockaliaservices.fr
BACKEND_URL=https://api.radar.jockaliaservices.fr

# === MCP ===
MCP_SECRET=generate_with_openssl_rand_hex_32
